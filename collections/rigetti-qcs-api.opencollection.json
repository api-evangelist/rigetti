          "docs": "Find an existing reservation by ID."
        },
        {
          "info": {
            "name": "Delete Reservation",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.qcs.rigetti.com/v1/reservations/:reservationId",
            "params": [
              {
                "name": "reservationId",
                "value": "",
                "type": "path"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Cancel an existing reservation for the user."
        },
        {
          "info": {
            "name": "Find Available Reservations",
            "type": "http"
